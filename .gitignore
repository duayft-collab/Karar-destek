# .gitignore
# Anayasa Kural 02 (Sıfır Hardcode): Credential dosyaları asla commit edilmez

# ── Firebase Credentials (KRİTİK) ──────────────────────────
# firebase.config.js içindeki gerçek değerleri içeren dosya
config/firebase.config.local.js
config/.env
.env
.env.local
.env.production

# ── Firebase Emulator ──────────────────────────────────────
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# ── OS & Editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Node (gelecekte kullanılabilir) ───────────────────────
node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# ── Build Output ──────────────────────────────────────────
dist/
build/
*.min.js.map

# ── Test Artifacts ────────────────────────────────────────
coverage/
.nyc_output/

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── Backup / Draft ────────────────────────────────────────
*.bak
*.draft
*-backup.*
